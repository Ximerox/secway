APP_NAME=SecWay
APP_ENV=production
# php artisan key:generate  (NIEMALS aendern, solange verschluesselte Daten existieren!)
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Berlin
APP_URL=https://secway.example.org
APP_LOCALE=de
APP_FALLBACK_LOCALE=de

LOG_CHANNEL=daily
LOG_LEVEL=warning
LOG_DAILY_DAYS=90

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=secway
DB_USERNAME=secway
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=sync

# Benachrichtigungs-Mails (Link, Kennwort, Erinnerung) gehen an den lokalen Postfix
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=25
MAIL_FROM_ADDRESS=secway@example.org
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# SecWay
# Alle Werte (ausser dem Secret) sind auch im Admin-Bereich pflegbar und
# werden dort persistiert; die .env-Werte dienen als Standard.
# ---------------------------------------------------------------------------

# Geheimnis, das das vorgelagerte Mailsystem (z. B. Exchange Online) als
# Header "X-MGW-Auth" mitschicken muss. Mails ohne gueltigen Header werden
# abgewiesen. Erzeugen z. B. mit: openssl rand -hex 32
MGW_INGEST_SECRET=

# Name des Betreibers, wie ihn Empfaenger sehen (Portal, Mails)
MGW_OPERATOR_NAME="Example GmbH"

# Eigene (interne) Domains, kommagetrennt - Empfaenger dieser Domains gelten
# als eingehende Mail (Entschluesselung, Signaturpruefung, Zertifikats-Ernte)
MGW_INTERNAL_DOMAINS=example.org

# Ausloese-Tag im Betreff fuer den Portal-Versand (wird vor Zustellung entfernt)
MGW_SUBJECT_TAG="[sicher]"

# Aufbewahrung im Portal (Tage), danach automatische Loeschung
MGW_RETENTION_DAYS=30

# Kennwort-Eingabe: Fehlversuche bis zur Sperre / Sperrdauer (Minuten)
MGW_MAX_ATTEMPTS=5
MGW_LOCKOUT_MINUTES=15

# Zeitversatz zwischen Link-Mail und Kennwort-Mail (Minuten, 0 = gleichzeitig)
MGW_PASSWORD_DELAY_MINUTES=2

# Erinnerung an nicht abgerufene Nachrichten nach X Stunden (0 = aus)
MGW_REMINDER_AFTER_HOURS=0

# Portal-Antworten: Empfaenger koennen im Portal antworten (Text + Anhaenge).
# Benoetigt clamav-daemon (Anhaenge werden vor Zustellung gescannt, fail-closed).
# Alle Werte auch in den Admin-Einstellungen pflegbar; dort gesetzte Werte gewinnen.
MGW_REPLY_ENABLED=false
MGW_REPLY_MAX_SIZE_MB=20
MGW_REPLY_MAX_PER_MESSAGE=5

# Quarantaene: eingehende S/MIME-Mails ohne passenden eigenen Schluessel
# zurueckhalten + benachrichtigen statt verschluesselt zuzustellen. Nach Ablauf
# der Frist wird automatisch unveraendert zugestellt (nichts bleibt liegen).
MGW_INBOUND_HOLD_ENABLED=false
MGW_INBOUND_HOLD_HOURS=72

# Empfaenger fuer Anwendungs-Benachrichtigungen (Quarantaene). Leer = keine Mail.
# Betriebsalarme der Ops-Skripte nutzen weiterhin ALERT_TO in /etc/secway.conf.
MGW_ADMIN_NOTIFY=

# ---------------------------------------------------------------------------
# Signaturblock-Modul (optional) — serverseitige E-Mail-Signaturen mit Daten
# aus Entra ID (Microsoft 365). Nur noetig, wenn dieses Modul genutzt wird.
# App-Registrierung + Berechtigungen: siehe docs/INSTALL.md, Abschnitt "Entra".
# ---------------------------------------------------------------------------

# Microsoft-Graph-Zugang (Client-Credentials-Flow einer App-Registrierung).
# Benoetigte Application-Berechtigungen (Admin-Consent!):
#   User.Read.All        - Benutzerattribute lesen (Pflicht fuers Modul)
#   GroupMember.Read.All  - nur wenn nach Entra-Gruppen gefiltert wird
#   Mail.ReadWrite        - nur fuer die Postausgang-Aktualisierung
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

# PHP-CLI-Binary fuer isolierte Subprozesse (QR-Code-Erzeugung). In FPM ist
# PHP_BINARY = php-fpm und damit ungeeignet, daher hier fest angeben.
MGW_PHP_BINARY=/usr/bin/php
